{
  "name": "@tetherto/mdk",
  "version": "0.3.0",
  "description": "MDK bootstrap utilities",
  "main": "index.js",
  "keywords": [
    "tether",
    "mdk"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "NODE_ENV=test brittle tests/unit/**/*.js",
    "test:integration": "NODE_ENV=test brittle tests/integration/**/*.js",
    "test:coverage": "brittle --coverage tests/**/*.js"
  },
  "dependencies": {
    "@bitfinex/bfx-facs-interval": "git+https://github.com/bitfinexcom/bfx-facs-interval.git",
    "@tetherto/hp-svc-facs-store": "git+https://github.com/tetherto/hp-svc-facs-store.git#v1.0.0",
    "@tetherto/svc-facs-action-approver": "git+https://github.com/tetherto/svc-facs-action-approver.git#v1.0.0"
  },
  "devDependencies": {
    "brittle": "3.18.0",
    "standard": "17.1.0"
  },
  "overrides": {
    "acorn": ">=8.17.0",
    "js-yaml": ">=4.3.0",
    "minimatch": ">=10.2.1",
    "qs": ">=6.15.3",
    "semver": ">=7.8.5",
    "tar": ">=7.5.19"
  }
}

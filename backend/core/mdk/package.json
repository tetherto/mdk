{
  "name": "@tetherto/mdk",
  "version": "0.5.0",
  "description": "MDK bootstrap utilities and worker-infra services — kernel/gateway lifecycle plus injectable log/comment/alert/stats/settings/provisioning services for runtime-hosted workers",
  "main": "index.js",
  "keywords": [
    "tether",
    "mdk"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "NODE_ENV=test brittle tests/unit/**/*.js",
    "test:integration": "NODE_ENV=test brittle 'tests/integration/**/*.test.js'",
    "test:coverage": "NODE_ENV=test brittle --coverage 'tests/**/*.test.js'"
  },
  "dependencies": {
    "@bitfinex/bfx-facs-http": "git+https://github.com/bitfinexcom/bfx-facs-http.git",
    "@bitfinex/bfx-facs-interval": "git+https://github.com/bitfinexcom/bfx-facs-interval.git",
    "@bitfinex/bfx-facs-scheduler": "git+https://github.com/bitfinexcom/bfx-facs-scheduler.git",
    "@bitfinex/lib-js-util-base": "git+https://github.com/bitfinexcom/lib-js-util-base.git",
    "@bitfinex/lib-js-util-promise": "git+https://github.com/bitfinexcom/lib-js-util-promise.git",
    "@tetherto/hp-svc-facs-store": "git+https://github.com/tetherto/hp-svc-facs-store.git#v1.0.0",
    "@tetherto/svc-facs-action-approver": "git+https://github.com/tetherto/svc-facs-action-approver.git#v1.0.0",
    "async": "3.2.6",
    "debug": "4.4.1",
    "mingo": "6.5.6",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "brittle": "3.18.0",
    "hyperdht": "^6.32.0",
    "standard": "17.1.0"
  }
}

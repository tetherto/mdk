{
  "name": "@tetherto/tpl-lib-thing",
  "version": "0.0.1",
  "description": "Template Lib Thing",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "NODE_ENV=test brittle tests/unit/*.js",
    "test:integration": "NODE_ENV=test brittle tests/integration/*.js",
    "test:coverage": "brittle --coverage tests/unit/*.js"
  },
  "dependencies": {
    "@bitfinex/bfx-facs-interval": "git+https://github.com/bitfinexcom/bfx-facs-interval.git",
    "@bitfinex/bfx-facs-scheduler": "git+https://github.com/bitfinexcom/bfx-facs-scheduler.git",
    "@bitfinex/lib-js-util-base": "git+https://github.com/bitfinexcom/lib-js-util-base.git",
    "@bitfinex/lib-js-util-promise": "git+https://github.com/bitfinexcom/lib-js-util-promise.git",
    "@hyperswarm/rpc": "3.5.0",
    "@tetherto/hp-svc-facs-store": "git+https://github.com/tetherto/hp-svc-facs-store.git#v1.0.0",
    "async": "3.2.6",
    "debug": "4.4.1",
    "hyperdht": "6.32.0",
    "hyperswarm": "4.17.0",
    "mingo": "6.5.6",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "brittle": "3.18.0",
    "standard": "17.1.2",
    "yargs": "17.7.2"
  },
  "overrides": {
    "minimatch": ">=10.2.1"
  }
}

{
  "name": "@tetherto/container-antspace",
  "version": "0.3.0",
  "description": "Container Antspace",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "NODE_ENV=test brittle tests/unit/*.js",
    "test:integration": "NODE_ENV=test brittle tests/integration/*.js",
    "test:coverage": "brittle --coverage tests/unit/*.js"
  },
  "dependencies": {
    "async": "3.2.6",
    "@bitfinex/bfx-facs-http": "git+https://github.com/bitfinexcom/bfx-facs-http.git"
  },
  "devDependencies": {
    "@bitfinex/lib-js-util-promise": "git+https://github.com/bitfinexcom/lib-js-util-promise.git",
    "brittle": "3.16.3",
    "fastify": "5.8.5",
    "standard": "17.1.2",
    "yargs": "17.7.2"
  },
  "overrides": {
    "acorn": ">=8.17.0",
    "js-yaml": ">=4.3.0",
    "minimatch": ">=10.2.1",
    "qs": ">=6.15.3",
    "semver": ">=7.8.5",
    "tar": ">=7.5.19"
  }
}

{
  "name": "@tetherto/miner-antminer",
  "version": "0.3.0",
  "description": "Miner Antminer",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "engine": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:integration": "NODE_ENV=test brittle tests/integration/*.js",
    "test:unit": "NODE_ENV=test brittle tests/unit/*.js",
    "test:coverage": "brittle --coverage tests/{,**/}*.test.js"
  },
  "dependencies": {
    "async": "3.2.6",
    "digest-fetch": "2.0.3",
    "node-fetch": "2.7.0"
  },
  "devDependencies": {
    "@bitfinex/lib-js-util-base": "git+https://github.com/bitfinexcom/lib-js-util-base.git",
    "@bitfinex/lib-js-util-promise": "git+https://github.com/bitfinexcom/lib-js-util-promise.git",
    "@fastify/passport": "3.0.2",
    "@fastify/secure-session": "8.3.0",
    "brittle": "3.16.3",
    "debug": "4.4.1",
    "passport-http": "0.3.0",
    "fastify": "5.8.5",
    "standard": "17.1.2",
    "yargs": "17.7.2"
  },
  "overrides": {
    "acorn": ">=8.17.0",
    "js-yaml": ">=4.3.0",
    "minimatch": ">=10.2.1",
    "qs": ">=6.15.3",
    "semver": ">=7.8.5",
    "tar": ">=7.5.19"
  }
}

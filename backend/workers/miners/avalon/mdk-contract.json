{
  "metadata": {
    "provider": "canaan",
    "deviceFamily": "miner",
    "brand": "Avalon",
    "modelsSupported": [
      "A1346"
    ],
    "overview": "Controls Canaan Avalon miners via TCP CGMiner API."
  },
  "capabilities": {
    "telemetry": [
      {
        "name": "hashrate_avg",
        "unit": "TH/s",
        "type": "number",
        "description": "Average hashrate."
      },
      {
        "name": "power",
        "unit": "W",
        "type": "number",
        "description": "Power draw."
      },
      {
        "name": "temperature",
        "unit": "C",
        "type": "number",
        "description": "Temperature."
      },
      {
        "name": "status",
        "unit": "",
        "type": "string",
        "description": "Device status."
      },
      {
        "name": "fan_speed",
        "unit": "RPM",
        "type": "number",
        "description": "Fan speed."
      }
    ],
    "commands": [
      {
        "name": "reboot",
        "description": "Restart miner.",
        "params": []
      },
      {
        "name": "setPowerMode",
        "description": "Change power mode.",
        "params": [
          {
            "name": "mode",
            "type": "string"
          }
        ]
      },
      {
        "name": "setLED",
        "description": "Toggle LED.",
        "params": [
          {
            "name": "enabled",
            "type": "boolean"
          }
        ]
      },
      {
        "name": "setupPools",
        "description": "Configure pools.",
        "params": [
          {
            "name": "pools",
            "type": "object"
          }
        ]
      },
      {
        "name": "registerThing",
        "params": [
          {
            "name": "info",
            "type": "object"
          },
          {
            "name": "opts",
            "type": "object"
          }
        ]
      },
      {
        "name": "updateThing",
        "params": [
          {
            "name": "info",
            "type": "object"
          }
        ]
      },
      {
        "name": "forgetThings",
        "params": [
          {
            "name": "ids",
            "type": "object"
          }
        ]
      },
      {
        "name": "saveSettings",
        "params": []
      },
      {
        "name": "saveComment",
        "params": [
          {
            "name": "text",
            "type": "string"
          }
        ]
      },
      {
        "name": "editComment",
        "params": [
          {
            "name": "commentId",
            "type": "string"
          },
          {
            "name": "text",
            "type": "string"
          }
        ]
      },
      {
        "name": "deleteComment",
        "params": [
          {
            "name": "commentId",
            "type": "string"
          }
        ]
      }
    ],
    "health": {
      "supportedStates": [
        "OK",
        "DEGRADED",
        "OFFLINE"
      ]
    },
    "errors": {
      "E_TEMP_HIGH": "Temperature exceeded threshold"
    }
  }
}

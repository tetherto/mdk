{
  "$schema": "../../../../core/mdk-worker/mdk-contract.schema.json",
  "metadata": {
    "provider": "canaan",
    "deviceFamily": "miner",
    "brand": "Avalon",
    "modelsSupported": ["A1346"],
    "overview": "Controls Canaan Avalon Bitcoin miners over the CGMiner ASCII API. Operations affect physical hardware — prioritize thermal safety."
  },
  "capabilities": {
    "telemetry": [
      { "name": "hashrate_avg", "unit": "TH/s", "type": "number", "handler": "src/telemetry/hashrate-avg.js", "description": "Average hashrate." },
      { "name": "power", "unit": "W", "type": "number", "handler": "src/telemetry/power.js", "description": "Current power draw." },
      { "name": "temperature", "unit": "C", "type": "number", "handler": "src/telemetry/temperature.js", "description": "Average chip temperature." },
      { "name": "fan_speed", "unit": "RPM", "type": "number", "handler": "src/telemetry/fan-speed.js", "description": "Average fan speed." },
      { "name": "status", "unit": "", "type": "string", "handler": "src/telemetry/status.js", "description": "Device status." },
      { "name": "uptime", "unit": "s", "type": "number", "handler": "src/telemetry/uptime.js", "description": "Seconds since last boot." },
      { "name": "efficiency", "unit": "W/TH", "type": "number", "handler": "src/telemetry/efficiency.js", "description": "Power efficiency." },
      { "name": "power_mode", "unit": "", "type": "string", "handler": "src/telemetry/power-mode.js", "description": "Current power mode." },
      { "name": "snap", "unit": "", "type": "object", "handler": "src/telemetry/snap.js", "description": "Full structured snapshot (stats + config), same shape the legacy metrics pull returned." }
    ],
    "commands": [
      {
        "name": "reboot",
        "description": "Restarts the miner controller. Takes 2-3 minutes to resume.",
        "constraints": "Do not call more than once per 5 minutes.",
        "handler": "src/commands/reboot.js",
        "params": []
      },
      {
        "name": "setPowerMode",
        "description": "Changes the power mode (sleep | normal | high).",
        "handler": "src/commands/set-power-mode.js",
        "params": [
          { "name": "mode", "type": "string" }
        ]
      },
      {
        "name": "setLED",
        "description": "Toggle the physical LED indicator (auto-disables after 2 minutes).",
        "handler": "src/commands/set-led.js",
        "params": [
          { "name": "enabled", "type": "boolean" }
        ]
      },
      {
        "name": "setupPools",
        "description": "Configure mining pools. Uses the worker's configured pools when none are passed.",
        "handler": "src/commands/setup-pools.js",
        "params": [
          { "name": "pools", "type": "object" }
        ]
      }
    ],
    "config": {
      "schema": "avalon_config_v1"
    },
    "health": {
      "supportedStates": ["OK", "DEGRADED", "OFFLINE"],
      "alerts": ["alert.overheat", "alert.hashboard_error", "alert.psu_failure", "alert.pool_dead"],
      "troubleshooting": [
        "If alert.overheat, verify fan speeds and ambient temperature.",
        "If alert.hashboard_error persists after reboot, escalate to operator.",
        "If status is OFFLINE, do not attempt reboot. Escalate to operator."
      ]
    },
    "errors": {
      "E_HASHBOARD": "Hash board in abnormal state",
      "E_PSU_ERR": "Power supply unit reporting error",
      "E_POOL_DEAD": "All configured pools unreachable"
    }
  }
}

{
  "$schema": "../../../../core/mdk-worker/mdk-contract.schema.json",
  "metadata": {
    "provider": "microbt",
    "deviceFamily": "miner",
    "brand": "Whatsminer",
    "modelsSupported": ["M30SP", "M30SPP", "M53S", "M56S", "M63"],
    "overview": "Controls MicroBT Whatsminer Bitcoin miners. Operations affect physical hardware — prioritize thermal safety."
  },
  "capabilities": {
    "telemetry": [
      { "name": "hashrate_rt", "unit": "TH/s", "type": "number", "handler": "src/telemetry/hashrate-rt.js", "description": "Real-time hashrate." },
      { "name": "hashrate_avg", "unit": "TH/s", "type": "number", "handler": "src/telemetry/hashrate-avg.js", "description": "Average hashrate." },
      { "name": "power", "unit": "W", "type": "number", "handler": "src/telemetry/power.js", "description": "Current power draw." },
      { "name": "temperature", "unit": "C", "type": "number", "handler": "src/telemetry/temperature.js", "description": "Chip temperature." },
      { "name": "fan_speed_in", "unit": "RPM", "type": "number", "handler": "src/telemetry/fan-speed-in.js", "description": "Inlet fan speed." },
      { "name": "fan_speed_out", "unit": "RPM", "type": "number", "handler": "src/telemetry/fan-speed-out.js", "description": "Outlet fan speed." },
      { "name": "status", "unit": "", "type": "string", "handler": "src/telemetry/status.js", "description": "Device status." },
      { "name": "uptime", "unit": "s", "type": "number", "handler": "src/telemetry/uptime.js", "description": "Seconds since last boot." },
      { "name": "accepted_shares", "unit": "", "type": "number", "handler": "src/telemetry/accepted-shares.js", "description": "Total accepted shares." },
      { "name": "rejected_shares", "unit": "", "type": "number", "handler": "src/telemetry/rejected-shares.js", "description": "Total rejected shares." },
      { "name": "pool_url", "unit": "", "type": "string", "handler": "src/telemetry/pool-url.js", "description": "Active pool URL." },
      { "name": "efficiency", "unit": "W/TH", "type": "number", "handler": "src/telemetry/efficiency.js", "description": "Power efficiency." },
      { "name": "power_mode", "unit": "", "type": "string", "handler": "src/telemetry/power-mode.js", "description": "Current power mode." },
      { "name": "snap", "unit": "", "type": "object", "handler": "src/telemetry/snap.js", "description": "Full structured snapshot (stats + config), same shape the legacy metrics pull returned." }
    ],
    "commands": [
      {
        "name": "reboot",
        "description": "Restarts the miner controller. Takes 2-3 minutes to resume.",
        "constraints": "Do not call more than once per 5 minutes.",
        "handler": "src/commands/reboot.js",
        "params": []
      },
      {
        "name": "setPowerMode",
        "description": "Changes the power mode.",
        "handler": "src/commands/set-power-mode.js",
        "params": [
          { "name": "mode", "type": "string" }
        ]
      },
      {
        "name": "setLED",
        "description": "Toggle the physical LED indicator.",
        "handler": "src/commands/set-led.js",
        "params": [
          { "name": "enabled", "type": "boolean" }
        ]
      },
      {
        "name": "setupPools",
        "description": "Configure mining pools. Uses the worker's configured pools when none are passed.",
        "handler": "src/commands/setup-pools.js",
        "params": [
          { "name": "pools", "type": "object" }
        ]
      },
      {
        "name": "setPowerPct",
        "description": "Set power percentage.",
        "handler": "src/commands/set-power-pct.js",
        "params": [
          { "name": "pct", "type": "number", "min": 0, "max": 200 }
        ]
      },
      {
        "name": "setUpfreqSpeed",
        "description": "Adjust the up-frequency speed (M63).",
        "handler": "src/commands/set-upfreq-speed.js",
        "params": [
          { "name": "speed", "type": "number" }
        ]
      }
    ],
    "config": {
      "schema": "whatsminer_config_v1"
    },
    "health": {
      "supportedStates": ["OK", "DEGRADED", "OFFLINE"],
      "alerts": ["alert.overheat", "alert.fan_failure", "alert.psu_failure", "alert.hashrate_low"],
      "troubleshooting": [
        "If alert.overheat, verify fan speeds. Fan speed of 0 is a mechanical failure.",
        "If alert.hashrate_low, miner may be tuning boards — wait 15 minutes.",
        "If status is OFFLINE, do not attempt reboot. Escalate to operator."
      ]
    },
    "errors": {
      "E_TEMP_HIGH": "Chip temperature exceeded safe thresholds",
      "E_FAN_FAIL": "Fan RPM below required threshold",
      "E_PSU_ERR": "Power supply unit reporting error"
    }
  }
}

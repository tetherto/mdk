{
  "name": "@tetherto/mdk-core",
  "version": "0.0.1",
  "description": "MDK Core",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "preinstall": "for pkg in packages/*/*; do if [ -f \"$pkg/package.json\" ]; then npm ci --prefix \"$pkg\"; fi; done",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration && npm run test:packages",
    "test:packages": "for pkg in packages/*/*; do if [ -f \"$pkg/package.json\" ]; then npm test --prefix \"$pkg\" || exit 1; fi; done",
    "test:unit": "NODE_ENV=test brittle tests/unit/**/*.test.js",
    "test:integration": "NODE_ENV=test npx brittle tests/integration/**/*.test.js",
    "test:coverage": "brittle --coverage tests/unit/**/*.js"
  },
  "dependencies": {
    "@bitfinex/bfx-facs-http": "git+https://github.com/bitfinexcom/bfx-facs-http.git",
    "@bitfinex/bfx-facs-interval": "git+https://github.com/bitfinexcom/bfx-facs-interval.git",
    "@bitfinex/bfx-svc-boot-js": "1.2.0",
    "@tetherto/hp-svc-facs-store": "git+https://github.com/tetherto/hp-svc-facs-store.git#v1.0.0",
    "@tetherto/svc-facs-action-approver": "git+https://github.com/tetherto/svc-facs-action-approver.git#v1.0.0"
  },
  "devDependencies": {
    "brittle": "3.18.0",
    "standard": "17.1.0"
  },
  "overrides": {
    "tar": ">=7.5.10",
    "fastify": "5.8.5",
    "@fastify/static": "9.1.3",
    "@fastify/oauth2": "8.2.0",
    "@fastify/websocket": "11.2.0"
  }
}

{
  "name": "@tetherto/container-bitdeer",
  "version": "0.0.1",
  "description": "MiniContainer Bitdeer",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "engine": {
    "node": ">=20.0"
  },
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "NODE_ENV=test brittle tests/unit/*.js",
    "test:integration": "NODE_ENV=test brittle tests/integration/*.js",
    "test:coverage": "brittle --coverage tests/{,**/}*.test.js"
  },
  "dependencies": {
    "@bitfinex/lib-js-util-base": "git+https://github.com/bitfinexcom/lib-js-util-base.git",
    "@bitfinex/lib-js-util-promise": "git+https://github.com/bitfinexcom/lib-js-util-promise.git",
    "@bitfinex/lib-js-util-task-queue": "git+https://github.com/bitfinexcom/lib-js-util-task-queue.git",
    "miningos-lib-stats": "git+https://github.com/tetherto/miningos-lib-stats.git",
    "svc-facs-mqtt": "git+https://github.com/tetherto/svc-facs-mqtt.git"
  },
  "devDependencies": {
    "aedes": "0.50.1",
    "brittle": "3.16.3",
    "standard": "17.1.2",
    "miningos-mock-control-service": "git+https://github.com/tetherto/miningos-mock-control-service.git",
    "yargs": "17.7.2"
  }
}

{
  "mode": "single-process",
  "noAuth": true,
  "env": "development",
  "services": [
    {
      "name": "ork",
      "kind": "ork"
    },
    {
      "name": "app-node",
      "kind": "app-node",
      "port": 3000
    },
    {
      "name": "am-s19xp",
      "kind": "worker",
      "worker": "miner-antminer",
      "type": "S19XP",
      "rack": "rack-s19xp",
      "mock": {
        "port": 14021,
        "container": "site-1",
        "serialNum": "AM-S19XP-001",
        "pos": "A01",
        "username": "root",
        "password": "root"
      }
    },
    {
      "name": "am-s19xph",

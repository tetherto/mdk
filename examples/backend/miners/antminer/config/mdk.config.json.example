      "worker": "miner-antminer",
      "type": "S21",
      "rack": "rack-s21",
      "mock": {
        "port": 14023,
        "container": "site-1",
        "serialNum": "AM-S21-001",
        "pos": "A03",
        "username": "root",
        "password": "root"
      }
    },
    {
      "name": "am-s21pro",
      "kind": "worker",
      "worker": "miner-antminer",
      "type": "S21PRO",
      "rack": "rack-s21pro",
      "mock": {
        "port": 14024,

{
  "name": "@tetherto/mdk-site",
  "version": "0.3.0",
  "description": "MDK Site",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "type": "commonjs",
  "scripts": {
    "setup:pm2": "node client-pm2.js",
    "setup:docker": "node client-docker.js",
    "start:pm2": "npm run setup:pm2 && pm2 start ecosystem.config.js",
    "start:docker": "npm run setup:docker && docker compose -f docker-compose.generated.yml up -d",
    "stop:docker": "docker compose -f docker-compose.generated.yml down",
    "docker:build": "docker build -f Dockerfile -t site-mdk ../../..",
    "lint": "standard",
    "lint:fix": "standard --fix"
  },
  "dependencies": {
    "@bitfinex/bfx-svc-boot-js": "1.2.0"
  }
}

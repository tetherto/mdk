{
  "name": "@tetherto/mdk-core-ui",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Core UI components, utilities, types, and theme system",
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./styles": "./src/styles/_mixins.scss"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "rimraf dist tsconfig.build.tsbuildinfo && pnpm build:scss && pnpm build:ts && node scripts/minify.mjs dist",
    "build:scss": "vite build",
    "build:ts": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist node_modules .turbo",
    "dev": "concurrently -n ts,scss -c cyan,magenta \"pnpm dev:ts\" \"pnpm dev:scss\"",
    "dev:scss": "vite build --watch",
    "dev:ts": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --config vitest.config.js --coverage",
    "typecheck": "tsc --noEmit",
    "watch": "pnpm dev",
    "watch:scss": "pnpm dev:scss",
    "watch:ts": "pnpm dev:ts"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^4.1.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-hook-form": "^7.54.0",
    "zod": "^3.24.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "catalog:",
    "@radix-ui/react-alert-dialog": "catalog:",
    "@radix-ui/react-avatar": "catalog:",
    "@radix-ui/react-checkbox": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-icons": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-popover": "catalog:",
    "@radix-ui/react-progress": "catalog:",
    "@radix-ui/react-radio-group": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-separator": "catalog:",
    "@radix-ui/react-slider": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-switch": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-toast": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "@radix-ui/react-use-controllable-state": "catalog:",
    "@tanstack/react-table": "catalog:",
    "chart.js": "catalog:",
    "chartjs-adapter-date-fns": "catalog:",
    "chartjs-plugin-datalabels": "catalog:",
    "chartjs-plugin-zoom": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "date-fns": "catalog:",
    "date-fns-tz": "catalog:",
    "lightweight-charts": "catalog:",
    "lodash": "catalog:",
    "prop-types": "catalog:",
    "react-chartjs-2": "catalog:",
    "react-day-picker": "catalog:",
    "react-gauge-chart": "catalog:"
  },
  "devDependencies": {
    "@hookform/resolvers": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/lodash": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "happy-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "terser": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}

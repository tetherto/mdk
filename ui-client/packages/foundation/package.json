{
  "name": "@tetherto/mdk-foundation-ui",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Complete foundation with features, state management, API client, hooks, and utilities",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./domain": {
      "types": "./dist/components/domain/index.d.ts",
      "import": "./dist/components/domain/index.js",
      "default": "./dist/components/domain/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./feature": {
      "types": "./dist/components/feature/index.d.ts",
      "import": "./dist/components/feature/index.js",
      "default": "./dist/components/feature/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "default": "./dist/hooks/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js",
      "default": "./dist/api/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js",
      "default": "./dist/state/index.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils/index.d.ts",
      "import": "./dist/test-utils/index.js",
      "default": "./dist/test-utils/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && pnpm build:ts && pnpm build:scss && pnpm postbuild",
    "build:ts": "tsc",
    "postbuild": "node scripts/postbuild.mjs",
    "build:scss": "vite build",
    "clean": "rimraf dist node_modules .turbo",
    "dev": "concurrently -n ts,scss -c cyan,magenta \"pnpm dev:ts\" \"pnpm dev:scss\"",
    "dev:ts": "tsc --watch",
    "dev:scss": "vite build --watch",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.js --maxConcurrency=5",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --config vitest.config.js --coverage",
    "lint:fix": "eslint . --fix",
    "format": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "@testing-library/react": "^16.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-redux": "^9.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "catalog:",
    "@radix-ui/react-icons": "catalog:",
    "@radix-ui/react-use-controllable-state": "catalog:",
    "@tetherto/mdk-core-ui": "workspace:*",
    "date-fns": "catalog:",
    "date-fns-tz": "catalog:",
    "lodash": "catalog:"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/lodash": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "happy-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "react-redux": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}

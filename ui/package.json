{
  "name": "mdk-ui",
  "type": "module",
  "version": "0.5.0",
  "private": true,
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "build:verbose": "turbo build --output-logs=full",
    "build:catalog": "VITE_BASE_PATH=/mdk turbo build --filter=@tetherto/mdk-catalog-ui",
    "build:scss": "turbo build:scss",
    "build:registry": "turbo run build:registry",
    "build:ts": "turbo build:ts",
    "check": "turbo check",
    "check:agent-ready": "turbo run check:agent-ready",
    "clean": "turbo clean && rimraf node_modules",
    "dev": "turbo dev",
    "dev:catalog": "VITE_BASE_PATH=/mdk turbo dev --filter=@tetherto/mdk-catalog-ui",
    "dev:packages": "turbo dev --filter=!@tetherto/mdk-catalog-ui",
    "format": "turbo format",
    "size": "node scripts/bundle-size.mjs",
    "size:consumer": "node scripts/treeshake-check.mjs",
    "size:check": "npm run build && npm run size && npm run size:consumer",
    "api:surface": "node scripts/generate-public-surface.mjs",
    "generate:shell": "npm run build && rimraf apps/mdk-ui-shell && node packages/cli/dist/bin.js create mdk-ui-shell",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:coverage": "turbo test:coverage",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint:scss": "stylelint 'packages/*/src/**/*.scss' 'apps/*/src/**/*.scss'",
    "prepare": "husky",
    "fullcheck": "npm run build && npm run lint && npm run typecheck && npm run format && npm run check:agent-ready --workspace @tetherto/mdk-react-devkit && npm run test:coverage",
    "preview:catalog": "VITE_BASE_PATH=/mdk turbo preview --filter=@tetherto/mdk-catalog-ui",
    "typecheck": "turbo typecheck",
    "watch": "turbo watch",
    "watch:scss": "turbo watch:scss",
    "watch:ts": "turbo watch:ts"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@tetherto/mdk-ui-cli": "*",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.24",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-format": "^1.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.14",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.97.3",
    "stylelint": "^17.11.1",
    "turbo": "^2.9.14",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "zod": "^3.24.0"
  },
  "workspaces": [
    "apps/*",
    "!apps/mdk-ui-shell",
    "!apps/starter",
    "packages/*"
  ],
  "overrides": {
    "@isaacs/brace-expansion": "5.0.5",
    "ajv@<6.14.0": ">=6.14.0",
    "brace-expansion@>=1.0.0 <1.1.13": ">=1.1.13",
    "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
    "brace-expansion@>=5.0.0 <5.0.5": ">=5.0.5",
    "cssnano": "^6.1.2",
    "cssnano-preset-default": "^6.1.2",
    "esbuild@>=0.17.0 <0.28.1": ">=0.28.1",
    "flatted@<3.4.2": ">=3.4.2",
    "glob": "^13.0.1",
    "glob@>=10.0.0 <11.0.0": "^13.0.1",
    "immutable@>=5.0.0 <5.1.5": ">=5.1.5",
    "lodash": "4.18.1",
    "minimatch@<3.1.3": ">=3.1.3",
    "minimatch@<3.1.4": ">=3.1.4",
    "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
    "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
    "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
    "picomatch@>=2.0.0 <2.3.2": ">=2.3.2",
    "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
    "postcss": "^8.5.14",
    "postcss-svgo": "^6.0.2",
    "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
    "undici@>=7.0.0 <7.28.0": "^7.28.0",
    "svgo": "^3.0.0",
    "vite@>=7.0.0 <8.0.16": ">=8.0.16",
    "ws@>=8.0.0 <=8.20.0": ">=8.20.1",
    "yaml@>=1.0.0 <1.10.3": ">=1.10.3",
    "yaml@>=2.0.0 <2.8.3": ">=2.8.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}

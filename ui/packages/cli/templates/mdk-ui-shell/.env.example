# Base URL of the App Node backend (miningos-app-node) for AUTHENTICATED
# data calls (/auth/*, /api/*). Leave EMPTY in development — Vite's dev
# server proxies `/auth`, `/api` etc. to the backend on :3000, so calls
# stay same-origin and dodge CORS. In production, set this only if your
# FE is on a different origin than the API; otherwise rely on the
# same-origin reverse proxy and keep it empty.
VITE_API_BASE_URL=

# Base URL of the OAuth backend. This MUST be absolute, because the sign-in
# button issues a full-page navigation (not an XHR) — the proxy doesn't help
# for top-level navigations. For local dev, the App Node serves both /auth
# and /oauth on :3000.
VITE_OAUTH_BASE_URL=http://localhost:3000

{
  "name": "@tetherto/mdk-react-devkit",
  "type": "module",
  "version": "0.3.0",
  "private": true,
  "description": "MDK Devkit (React) — generic UI primitives (src/core) plus mining-domain components, hooks, and state bindings (src/foundation)",
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./foundation": {
      "types": "./dist/foundation/index.d.ts",
      "import": "./dist/foundation/index.js",
      "default": "./dist/foundation/index.js"
    },
    "./domain": {
      "types": "./dist/foundation/components/index.d.ts",
      "import": "./dist/foundation/components/index.js",
      "default": "./dist/foundation/components/index.js"
    },
    "./feature": {
      "types": "./dist/foundation/features/index.d.ts",
      "import": "./dist/foundation/features/index.js",
      "default": "./dist/foundation/features/index.js"
    },
    "./registry.json": "./dist/registry.json",
    "./blueprints.json": "./dist/blueprints.json",
    "./styles.css": "./dist/styles.css",
    "./styles": "./src/core/styles/_mixins.scss",
    "./tokens.scss": "./src/core/styles/_colors.scss",
    "./src/styles/index.scss": "./src/foundation/styles/index.scss"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "AGENT_READY.md",
    "blueprints/*.md",
    "dist",
    "src",
    "src/**/*.example.tsx",
    "src/**/USAGE.md"
  ],
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo && npm run build:ts && npm run build:scss && npm run build:registry",
    "build:registry": "tsx scripts/generate-registry.mts",
    "build:scss": "vite build",
    "build:ts": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node scripts/strip-style-imports.mjs dist",
    "clean": "rimraf dist node_modules .turbo",
    "dev": "concurrently -n ts,scss -c cyan,magenta \"npm run dev:ts\" \"npm run dev:scss\"",
    "dev:ts": "node scripts/tsc-watch-strip.mjs",
    "dev:scss": "vite build --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "eslint . --fix",
    "check:agent-ready": "npm run build:registry && node scripts/check-agent-ready.mjs",
    "test": "vitest run --config vitest.config.js --maxConcurrency=5",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --config vitest.config.js --coverage",
    "typecheck": "tsc --noEmit",
    "watch": "npm run dev",
    "watch:ts": "npm run dev:ts",
    "watch:scss": "npm run dev:scss"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^4.1.0",
    "@testing-library/react": "^16.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "vitest": "^4.0.0",
    "zod": "^3.24.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.25",
    "@tetherto/mdk-react-adapter": "^0.3.0",
    "@tetherto/mdk-ui-core": "^0.3.0",
    "chart.js": "^4.4.9",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "chartjs-plugin-zoom": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lightweight-charts": "^4.1.7",
    "lodash": "^4.18.1",
    "react-chartjs-2": "^5.2.0",
    "react-day-picker": "^9.13.1",
    "react-selecto": "^1.26.3",
    "react-zoom-pan-pinch": "^4.0.3"
  },
  "devDependencies": {
    "@hookform/resolvers": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "happy-dom": "^20.0.0",
    "jsdom": "^28.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.54.0",
    "ts-morph": "^24.0.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.2",
    "vitest": "^4.1.2",
    "zod": "^3.24.0"
  }
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "rootDir": "./src",
    "paths": {
      "@primitives": ["./src/primitives"],
      "@primitives/*": ["./src/primitives/*"],
      "@domain/*": ["./src/domain/*"]
    },
    "declarationDir": "./dist",
    "noEmit": false,
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"]
}
